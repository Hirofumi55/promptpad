---
import BaseLayout from '../layouts/BaseLayout.astro';
import { App } from '../components/App';
---

<BaseLayout
  title="PromptPad | AIプロンプトを保存・整理・すぐコピーできる無料メモ帳"
  description="PromptPad は、ChatGPT・Claude・Gemini などの AI プロンプトをブラウザだけで保存・整理・ワンクリックコピーできる無料メモ帳アプリです。"
>
  <h1 class="sr-only">PromptPad - AIプロンプト専用メモ帳</h1>
  <noscript>
    <div
      style="
        padding: 16px;
        border-bottom: 1px solid #e2e8f0;
        background: #fff7ed;
        color: #9a3412;
        font: 500 14px/1.6 system-ui, sans-serif;
      "
    >
      JavaScript を有効にすると PromptPad を利用できます。
    </div>
  </noscript>
  <App client:only="preact" />
</BaseLayout>
